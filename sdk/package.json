{
  "name": "@mini-plausible/sdk",
  "version": "1.0.0",
  "description": "Lightweight privacy-first analytics SDK for Mini Plausible",
  "main": "dist/plausible.min.js",
  "module": "dist/plausible.esm.js",
  "types": "dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "rollup -c",
    "build:esbuild": "esbuild src/index.ts --bundle --minify --outfile=dist/plausible.min.js --format=iife --global-name=plausible",
    "dev": "rollup -c --watch"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "rollup": "^4.0.0",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-typescript": "^12.0.0",
    "rollup-plugin-terser": "^7.0.2",
    "tslib": "^2.8.0",
    "typescript": "^5.0.0"
  },
  "license": "MIT"
}